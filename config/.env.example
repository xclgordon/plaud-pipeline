# Plaud Pipeline — 环境变量配置
# 复制此文件为 .env 并填入真实值
# cp config/.env.example .env

# === LLM 配置 ===
# Claude CLI 路径（默认: 系统 PATH 中的 claude）
# CLAUDE_BIN=claude

# 或使用 OpenAI 兼容接口
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# === 通知配置（可选） ===
# Telegram Bot
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234gh...
# TELEGRAM_HOME_CHANNEL=-1001234567890
# TELEGRAM_PROXY=http://127.0.0.1:20171

# === 路径配置（可选，默认值通常够用） ===
# 数据目录
# PLAUD_DATA_DIR=~/plaud-knowledge-base
# 配置文件目录（含 org_chart.md 等）
# PLAUD_CONFIG_DIR=~/plaud-pipeline/config

# === HuggingFace（pyannote 模型下载） ===
# 如果网络不通，设置离线模式
# HF_HUB_OFFLINE=1
